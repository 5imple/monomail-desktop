# Google OAuth credentials (Desktop app type in Google Cloud Console).
# Required for direct Google OAuth sign-in (PKCE). Leave blank to use the
# MONO_ENV_HOMEPAGE_DOMAIN backend sign-in page instead.
MONO_ENV_GOOGLE_CLIENT_ID=
MONO_ENV_GOOGLE_CLIENT_SECRET=

MONO_ENV_FIREBASE_API_KEY=VALUE
MONO_ENV_FIREBASE_AUTH_DOMAIN=VALUE
MONO_ENV_FIREBASE_PROJECT_ID=VALUE
MONO_ENV_FIREBASE_STORAGE_BUCKET=VALUE
MONO_ENV_FIREBASE_MESSAGING_SENDER_ID=VALUE
MONO_ENV_FIREBASE_APP_ID=VALUE
MONO_ENV_FIREBASE_MEASUREMENT_ID=VALUE
MONO_ENV_FIREBASE_VAPID_KEY=VALUE
MONO_ENV_HOMEPAGE_DOMAIN=VALUE
MONO_ENV_API_URL=VALUE
MONO_ENV_APP_VERSION=VALUE
MONO_ENV_MIXPANEL_TOKEN=VALUE
MONO_ENV_PROTOCOL=VALUE
MONO_ENV_SUPPORT_EMAIL=support@example.com
MONO_ENV_COOKIE_DOMAIN=
MONO_ENV_UTM_SOURCE=app
MONO_ENV_CAREERS_URL=
MONO_ENV_BRAND_EMAIL_DOMAIN=
MONO_ENV_SOCIAL_X_URL=
MONO_ENV_DISCORD_INVITE_URL=
