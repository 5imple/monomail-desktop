# ─────────────────────────────────────────────────────────────────────────────
# Standalone Google mode (no backend required)
# Create credentials at: docs/GOOGLE_OAUTH_SETUP.md
# ─────────────────────────────────────────────────────────────────────────────
MONO_ENV_GOOGLE_CLIENT_ID=
MONO_ENV_GOOGLE_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Optional feature backend (signatures, templates, spaces, contacts, etc.).
# Leave blank to run fully standalone on Gmail.
# ─────────────────────────────────────────────────────────────────────────────
MONO_ENV_API_URL=
MONO_ENV_PROTOCOL=mono-desktop

# ─────────────────────────────────────────────────────────────────────────────
# App metadata
# ─────────────────────────────────────────────────────────────────────────────
MONO_ENV_APP_VERSION=1.0.0-dev
MONO_ENV_SUPPORT_EMAIL=support@example.com
MONO_ENV_PUBLIC_DOMAIN=
MONO_ENV_UPDATE_FEED_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Analytics (optional — leave blank to disable)
# ─────────────────────────────────────────────────────────────────────────────
MONO_ENV_MIXPANEL_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# UI / branding (all optional)
# ─────────────────────────────────────────────────────────────────────────────
MONO_ENV_COOKIE_DOMAIN=
MONO_ENV_UTM_SOURCE=app
MONO_ENV_CAREERS_URL=
MONO_ENV_BRAND_EMAIL_DOMAIN=
MONO_ENV_SOCIAL_X_URL=
MONO_ENV_DISCORD_INVITE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# Legacy / deprecated — kept so old .env files don't crash the env loader.
# These vars are no longer read by any code. Safe to delete from your local
# .env.development once you've migrated to Google OAuth or on-prem mode.
# ─────────────────────────────────────────────────────────────────────────────
# MONO_ENV_FIREBASE_API_KEY=
# MONO_ENV_FIREBASE_AUTH_DOMAIN=
# MONO_ENV_FIREBASE_PROJECT_ID=
# MONO_ENV_FIREBASE_STORAGE_BUCKET=
# MONO_ENV_FIREBASE_MESSAGING_SENDER_ID=
# MONO_ENV_FIREBASE_APP_ID=
# MONO_ENV_FIREBASE_MEASUREMENT_ID=
# MONO_ENV_FIREBASE_VAPID_KEY=
