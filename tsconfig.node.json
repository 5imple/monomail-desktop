{
  "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
  "include": ["electron.vite.config.*", "src/main/**/*", "src/preload/**/*", "src/common/**/*", "types/vite-env.d.ts"],
  "compilerOptions": {
    "composite": true,
    
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["electron-vite/node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
    }
  }
}
