    "@tiptap/extension-text-style": "^2.10.3",
    "@tiptap/extension-typography": "^2.10.2",
    "@tiptap/extension-underline": "^2.11.7",
    "@tiptap/html": "^2.10.3",
    "@tiptap/react": "^2.4.0",
