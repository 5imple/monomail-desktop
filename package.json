{
  "name": "monomail-desktop",
  "version": "1.1.5-dev",
  "description": "Desktop email client (Electron)",
  "main": "./out/main/index.js",
  "author": "Open source contributors",
  "homepage": "https://github.com/erickim20/monomail-desktop",
  "license": "MIT",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint . --ext .js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run build:tailwind && npm run typecheck && electron-vite build",
    "build:dev": "npm run build:tailwind && npm run typecheck && electron-vite build --mode development",
    "build:prod": "npm run build:tailwind && npm run typecheck && electron-vite build --mode production",
    "set-channel": "node ./scripts/setChannel.js",
    "set-channel:dev": "node ./scripts/setChannel.js dev",
    "set-channel:prod": "node ./scripts/setChannel.js latest",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:mac:dev": "npm run set-channel:dev && npm run build:dev && electron-builder --mac",
    "build:mac:prod": "npm run set-channel:prod && npm run build:prod && electron-builder --mac",
    "build:tailwind": "npx tailwindcss -i ./src/renderer/global.css -o ./src/renderer/app/assets/style/tailwind.css --minify"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@hookform/resolvers": "^3.9.0",
