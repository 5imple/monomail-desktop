    "@tiptap/extension-highlight": "^2.10.2",
    "@tiptap/extension-image": "^2.4.0",
    "@tiptap/extension-link": "^2.10.3",
    "@tiptap/extension-placeholder": "^2.4.0",
    "@tiptap/extension-table": "^2.10.4",
    "@tiptap/extension-table-cell": "^2.10.4",
